{
  "name": "autobuild",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "ab": "bin/ab.ts"
  },
  "exports": {
    "./plugin-sdk": {
      "types": "./src/plugin-sdk/index.ts",
      "import": "./src/plugin-sdk/index.ts",
      "default": "./src/plugin-sdk/index.ts"
    }
  },
  "files": [
    "bin",
    "src",
    "skills",
    "templates",
    "README.md",
    "SPEC.md",
    "docs"
  ],
  "scripts": {
    "dev": "bun --hot --no-clear-screen bin/ab-dev.ts",
    "capture:dashboard": "bun tools/dashboard-capture.ts",
    "check": "bun tools/biome-check.ts",
    "format:staged": "git-format-staged --formatter './node_modules/.bin/biome format --stdin-file-path {}' '*.js' '*.jsx' '*.ts' '*.tsx' '*.json' '*.jsonc' '*.css' '*.graphql' '*.gql'",
    "prepare": "husky",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.10",
    "drizzle-orm": "^0.45.2",
    "semver": "^7.7.4",
    "smol-toml": "^1.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@resvg/resvg-js": "2.6.2",
    "@types/bun": "^1.3.14",
    "@types/semver": "^7.7.1",
    "dejavu-fonts-ttf": "2.37.0",
    "drizzle-kit": "^0.31.10",
    "git-format-staged": "4.0.1",
    "husky": "9.1.7",
    "typescript": "^7.0.2"
  }
}
